---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema, abs } from '../lib/seo';

const description = "A step-by-step guide to downloading Bob Wallet, installing the Chrome extension, and exploring Handshake (HNS) decentralized domains.";

const steps = [
  {
    num: 1,
    featured: true,
    title: 'Download Bob Wallet',
    body: 'The premier desktop wallet for managing your HNS coins and domain names securely. Start here — it\'s the foundation for everything else.',
    tutorial: 'https://skyinclude.com/blog/boblearnhns/',
    actions: [
      { href: 'https://bobwallet.org/download/bob-learnhns', label: 'LearnHNS 2026 Version', primary: true },
      { href: 'https://bobwallet.org/download/bob-wallet', label: '2024 Version' },
    ],
  },
  {
    num: 2,
    title: 'Install Chrome Extension',
    body: 'Interact with Handshake domains directly from your browser with the Bob Wallet extension.',
    tutorial: 'https://skyinclude.com/blog/learnhns-wallet/',
    actions: [
      { href: 'https://bobwallet.org/extension/learnhns-wallet/', label: 'LearnHNS 2026 Version', primary: true },
      { href: 'https://bobwallet.org/extension/shake-wallet/', label: '2024 Version' },
    ],
  },
  {
    num: 3,
    title: 'Visit ShakeDex Marketplace',
    body: 'Buy and sell Handshake domains on our decentralized web marketplace channel.',
    tutorial: 'https://skyinclude.com/blog/shakedex-learnhns/',
    actions: [
      { href: '/market/', label: 'Learn About Our Market', primary: true },
      { href: 'https://shakedex.org/markets', label: 'More Shakedex Channels' },
    ],
  },
  {
    num: 4,
    title: 'Buy/Sell HNS',
    body: 'Easily trade Handshake coins (HNS) through the decentralized Liquidity Spot.',
    tutorial: 'https://skyinclude.com/blog/liquidity-spot/',
    actions: [
      { href: 'https://liquidity.spot', label: 'Visit Liquidity Spot', primary: true },
      { href: 'https://liquidity.spot/opensource', label: 'Make Your Own' },
    ],
  },
  {
    num: 5,
    title: 'Browse HNS Sites',
    body: 'Download the open source SkyInclude Browser to easily and quickly open and navigate Handshake websites.',
    tutorial: 'https://skyinclude.com/blog/skyinclude-browser-launch/',
    actions: [
      { href: 'https://skyinclude.com/browser', label: 'Download for Mac, Windows, Linux', primary: true },
      { href: 'https://github.com/shadstoneofficial/skyinclude-browser#readme', label: 'Verify Source Code' },
    ],
  },
  {
    num: 6,
    title: 'Host Handshake Sites',
    body: 'Sign up for Host.limo to use various Handshake hosting options, from free Headlessdomains hosting to Pages to Handout.',
    tutorial: '/docs/starting-from-zero/how-to-create-a-handshake-website',
    actions: [
      { href: 'https://my.host.limo', label: 'Visit Host.limo', primary: true },
      { href: '/handout/', label: 'Make Your Own Handout Server' },
    ],
  },
  {
    num: 7,
    title: 'Contribute Blog Content',
    body: 'This LearnHNS Blog is community-centric. Read our latest articles or contribute your own knowledge to the ecosystem.',
    tutorial: 'https://skyinclude.com/blog/learnhns-kickoff/',
    actions: [
      { href: '/blog/', label: 'Visit Blog', primary: true },
      { href: '/blog/become-contributor/', label: 'Become a Contributor' },
    ],
  },
  {
    num: 8,
    title: 'Join the Community',
    body: 'Participate in GitHub development, join discussions, and help build the future of the decentralized web.',
    tutorial: 'https://skyinclude.com/blog/handshake2026/',
    actions: [
      { href: 'https://github.com/handshake-org', label: 'GitHub' },
      { href: 'https://t.me/handshake_hns', label: 'Telegram' },
    ],
  },
];
---
<BaseLayout
  title="Get Started with Handshake Tools"
  description={description}
  keywords="Handshake setup, Bob Wallet, HNS Chrome extension, ShakeDex, Liquidity Spot, HNS getting started"
  schema={[
    webPageSchema({ title: 'Get Started with Handshake Tools', description, url: abs('/start/') }),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Start Here', path: '/start/' },
    ]),
  ]}
>
  <div class="page-shell">

    <section class="page-hero">
      <div class="page-hero-eyebrow">Setup Guide</div>
      <h1 class="page-hero-title">
        Start using <em>Handshake.</em>
      </h1>
      <p class="page-hero-lede">
        Ready to dive into the Handshake ecosystem? Follow these steps to set up
        your decentralized tools and start exploring marketplaces on HNS.
      </p>
    </section>

    <section class="page-section steps-section">
      <div class="section-label">The path</div>

      {steps.filter((step) => step.featured).map((step) => (
        <article class="step-card step-card--featured">
          <span class="step-badge">{step.num}</span>
          <div class="step-body">
            <h2>{step.title}</h2>
            <p>{step.body}</p>
            <div class="btn-group">
              {step.actions.map((action) => (
                <a
                  href={action.href}
                  target={action.href.startsWith('http') ? '_blank' : undefined}
                  rel={action.href.startsWith('http') ? 'noopener' : undefined}
                  class={action.primary ? 'primary-btn' : 'btn'}
                >
                  {action.label}
                </a>
              ))}
              {step.tutorial && (
                <a
                  href={step.tutorial}
                  target={step.tutorial.startsWith('http') ? '_blank' : undefined}
                  rel={step.tutorial.startsWith('http') ? 'noopener' : undefined}
                  class="btn btn-tutorial"
                >
                  Read Tutorial &rarr;
                </a>
              )}
            </div>
          </div>
        </article>
      ))}

      <div class="steps-grid">
        {steps.filter((step) => !step.featured).map((step) => (
          <article class="step-card">
            <span class="step-badge">{step.num}</span>
            <div class="step-body">
              <h2>{step.title}</h2>
              <p>{step.body}</p>
              <div class="btn-group">
                {step.actions.map((action) => (
                  <a
                    href={action.href}
                    target={action.href.startsWith('http') ? '_blank' : undefined}
                    rel={action.href.startsWith('http') ? 'noopener' : undefined}
                    class={action.primary ? 'primary-btn' : 'btn'}
                  >
                    {action.label}
                  </a>
                ))}
                {step.tutorial && (
                  <a
                    href={step.tutorial}
                    target={step.tutorial.startsWith('http') ? '_blank' : undefined}
                    rel={step.tutorial.startsWith('http') ? 'noopener' : undefined}
                    class="btn btn-tutorial"
                  >
                    Read Tutorial &rarr;
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .page-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .step-card {
    position: relative;
    background: var(--surface);
    padding: 2rem 2rem 2rem 4rem;
    border-radius: 14px;
    border: 1px solid var(--glass-border);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .step-card:hover {
    transform: translateY(-3px);
    border-color: var(--hns-violet);
    box-shadow: 0 12px 32px rgba(105, 58, 250, 0.1);
  }

  .step-badge {
    position: absolute;
    top: 2rem;
    left: 1.5rem;
    width: 32px;
    height: 32px;
    background: var(--hns-violet);
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-mono);
    box-shadow: 0 4px 14px rgba(105, 58, 250, 0.35);
  }

  .step-card h2 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .step-card p {
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  /* Featured step gets a bigger badge + larger title */
  .step-card--featured {
    padding: 2.5rem 2.5rem 2.5rem 5rem;
    background: linear-gradient(135deg, var(--surface), rgba(105, 58, 250, 0.03));
    border-color: rgba(105, 58, 250, 0.25);
    margin-bottom: 2rem;
  }

  .step-card--featured .step-badge {
    top: 2.5rem;
    left: 2rem;
    width: 44px;
    height: 44px;
    font-size: 1.3rem;
  }

  .step-card--featured h2 {
    font-size: 1.85rem;
  }

  .step-card--featured p {
    font-size: 1.05rem;
    max-width: 640px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .primary-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--hns-violet);
    color: #ffffff;
    border: 1px solid var(--hns-violet);
    padding: 0.55rem 1.1rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .primary-btn:hover {
    background: var(--hns-violet-deep);
    border-color: var(--hns-violet-deep);
    color: #ffffff;
    text-decoration: none;
  }

  .btn-group {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn-tutorial {
    border-style: dashed;
  }

  @media (max-width: 800px) {
    .steps-grid { grid-template-columns: 1fr; }
    .step-card { padding: 1.75rem 1.5rem 1.75rem 3.5rem; }
    .step-card--featured { padding: 2rem 1.75rem 2rem 4rem; }
    .step-badge { left: 1rem; top: 1.75rem; }
    .step-card--featured .step-badge { left: 1.25rem; top: 2rem; }
  }
</style>
