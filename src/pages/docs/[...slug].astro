---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsArchiveNotice from '../../components/DocsArchiveNotice.astro';
import { isArchivedDocId } from '../../lib/rehype-dead-links.mjs';

export async function getStaticPaths() {
  const docsEntries = await getCollection('docs');
  return docsEntries
    .filter(entry => entry.id !== 'readme') // Filter out readme, it's handled by index.astro
    .map(entry => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const archived = entry.data.archived ?? isArchivedDocId(entry.id);
const mirroredFrom = entry.data.mirroredFrom;

// Generate the GitHub edit URL
const editUrl = `https://github.com/shadstoneofficial/learnhns-web/edit/main/src/content/docs/${entry.id}.md`;
---

<BaseLayout 
  title={`${entry.id === 'readme' ? 'Introduction' : entry.id} | LearnHNS Docs`} 
  description="LearnHNS Documentation Archive"
>
  <div class="page-content" style="max-width: 800px; margin: 2rem auto; padding: 2rem; background: var(--surface); border: 1px solid var(--glass-border); border-radius: 12px;">
    
    <DocsArchiveNotice editUrl={editUrl} archived={archived} mirroredFrom={mirroredFrom} />

    <article class="markdown-body">
      <Content />
    </article>
  </div>
</BaseLayout>

<style is:global>
  /* Markdown Content Styling matching global.css theme */
  .markdown-body {
    font-family: var(--font-sans);
    line-height: 1.7;
    color: var(--text-primary);
  }
  .markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-family: var(--font-serif);
    font-weight: 700;
  }
  .markdown-body h1 { font-size: 2.5rem; }
  .markdown-body h2 { font-size: 2rem; border-bottom: 1px solid var(--glass-border); padding-bottom: 0.5rem; }
  .markdown-body h3 { font-size: 1.5rem; }
  .markdown-body p {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }
  .markdown-body ul, .markdown-body ol {
    margin-bottom: 1.25rem;
    padding-left: 2rem;
    color: var(--text-secondary);
  }
  .markdown-body li {
    margin-bottom: 0.5rem;
  }
  .markdown-body a {
    color: var(--hns-violet);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .markdown-body a:hover {
    color: var(--hns-violet-deep);
  }
  .markdown-body a.dead-link {
    text-decoration: line-through;
    text-decoration-color: rgba(180, 120, 0, 0.7);
    opacity: 0.75;
  }
  .markdown-body a.dead-link::after {
    content: ' (offline)';
    font-size: 0.75em;
    font-weight: 600;
    text-decoration: none;
    color: rgba(180, 120, 0, 0.9);
  }
  .markdown-body pre {
    background: rgba(0,0,0,0.2);
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--glass-border);
  }
  [data-theme="dark"] .markdown-body pre {
    background: #000000;
  }
  .markdown-body code {
    background: rgba(105, 58, 250, 0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--hns-violet);
  }
  .markdown-body pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .markdown-body blockquote {
    border-left: 4px solid var(--hns-violet);
    padding-left: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    background: rgba(105, 58, 250, 0.03);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    border-radius: 0 8px 8px 0;
  }
  .markdown-body img {
    max-width: 100%;
    border-radius: 8px;
    margin: 2rem 0;
    border: 1px solid var(--glass-border);
  }
</style>
