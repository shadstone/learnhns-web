---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Learn HNS - Understanding Handshake">
  <div class="content-wrapper">
    <h1>Learn About Handshake</h1>
    <div class="content">
      <section class="learn-section">
        <h2>Essential Resources</h2>
        <ul class="resource-list">
          <li>
            <h3>Official Documentation</h3>
            <p>Comprehensive technical documentation for developers and users</p>
            <a href="https://hsd-dev.org" target="_blank" class="btn">HSD Documentation</a>
          </li>
          <li>
            <h3>Handshake Whitepaper</h3>
            <p>Technical overview of the Handshake protocol</p>
            <a href="https://handshake.org/files/handshake.txt" target="_blank" class="btn">Read Whitepaper</a>
          </li>
          <li>
            <h3>Namebase Learn</h3>
            <p>Beginner-friendly guides and tutorials</p>
            <a href="https://learn.namebase.io" target="_blank" class="btn">Visit Namebase Learn</a>
          </li>
          <li>
            <h3>HNS Development Guide</h3>
            <p>Technical guide for developers building on Handshake</p>
            <a href="https://hsd-dev.org/guides/protocol.html" target="_blank" class="btn">Read Development Guide</a>
          </li>
          <li>
            <h3>Handshake FAQ</h3>
            <p>Frequently asked questions about Handshake</p>
            <a href="https://handshake.org/faq/" target="_blank" class="btn">Read FAQ</a>
          </li>
          <li>
            <h3>Skyinclude Blog</h3>
            <p>In-depth articles and tutorials about Handshake technology</p>
            <a href="https://skyinclude.com/blog" target="_blank" class="btn">Read Blog</a>
          </li>
        </ul>
      </section>

      <section class="learn-section" style="margin-top: 3rem;">
        <h2>Community Resources</h2>
        <ul class="resource-list">
          <li>
            <h3>Handshake Community</h3>
            <p>Join the discussion on Telegram</p>
            <a href="https://t.me/handshake_hns" target="_blank" class="btn">Join Telegram</a>
          </li>
          <li>
            <h3>Developer Community</h3>
            <p>Technical discussions and development chat</p>
            <a href="https://t.me/hns_tech" target="_blank" class="btn">Join Developer Chat</a>
          </li>
          <li>
            <h3>GitHub Repository</h3>
            <p>Source code and technical resources</p>
            <a href="https://github.com/handshake-org" target="_blank" class="btn">View on GitHub</a>
          </li>
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>
