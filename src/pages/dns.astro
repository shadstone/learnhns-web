---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema, abs } from '../lib/seo';

const description = "Understand the difference between traditional centralized DNS and Handshake's decentralized naming architecture with helpful diagrams.";
---
<BaseLayout
  title="How DNS Works vs. Handshake (HNS)"
  description={description}
  keywords="how DNS works, DNS vs Handshake, decentralized DNS, ICANN alternative, DNSSEC, HNS root zone, blockchain DNS"
  schema={[
    webPageSchema({ title: 'How DNS Works vs. Handshake', description, url: abs('/dns/') }),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'How DNS Works', path: '/dns/' },
    ]),
  ]}
>
  <div class="page-shell">

    <section class="page-hero">
      <div class="page-hero-eyebrow">Protocol Deep Dive</div>
      <h1 class="page-hero-title">
        How DNS <em>actually</em> works.
      </h1>
      <p class="page-hero-lede">
        The Domain Name System is the internet's address book — translating
        human-readable names into IP addresses. Here's how the traditional model
        works, and how Handshake rebuilds the root.
      </p>
    </section>

    <section class="page-section">
      <div class="section-label">Diagrams</div>
      <h2 class="section-heading">Visual references.</h2>
      <p class="page-section-lede">Click any diagram to open the full-resolution image.</p>

      <div class="diagram-grid">
        <a href="/images/dns/dns-resolution-flow.png" target="_blank" class="diagram-card diagram-card--featured">
          <div class="diagram-thumb">
            <img src="/images/dns/dns-resolution-flow.png" alt="DNS Resolution Flow" loading="lazy" />
          </div>
          <div class="diagram-caption">
            <div class="diagram-eyebrow">Featured</div>
            <p>DNS Resolution Process Flow</p>
          </div>
        </a>

        <a href="/images/dns/dns-vs-hns.png" target="_blank" class="diagram-card">
          <div class="diagram-thumb">
            <img src="/images/dns/dns-vs-hns.png" alt="DNS vs HNS Comparison" loading="lazy" />
          </div>
          <p>Traditional DNS vs Handshake HNS</p>
        </a>

        <a href="/images/dns/hns-resolution-flow.png" target="_blank" class="diagram-card">
          <div class="diagram-thumb">
            <img src="/images/dns/hns-resolution-flow.png" alt="Handshake Resolution Flow" loading="lazy" />
          </div>
          <p>Handshake Name Resolution Process</p>
        </a>

        <a href="/images/dns/centralized-vs-decentralized.png" target="_blank" class="diagram-card">
          <div class="diagram-thumb">
            <img src="/images/dns/centralized-vs-decentralized.png" alt="Centralized vs Decentralized DNS" loading="lazy" />
          </div>
          <p>Centralized vs Decentralized DNS Structure</p>
        </a>

        <a href="/images/dns/covenant-limits.png" target="_blank" class="diagram-card">
          <div class="diagram-thumb">
            <img src="/images/dns/covenant-limits.png" alt="Handshake Covenant Limits" loading="lazy" />
          </div>
          <p>Handshake Protocol Covenant Limits</p>
        </a>

        <a href="/images/dns/handshake-stack.png" target="_blank" class="diagram-card">
          <div class="diagram-thumb">
            <img src="/images/dns/handshake-stack.png" alt="Handshake Technical Stack" loading="lazy" />
          </div>
          <p>Handshake Technical Stack</p>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Key differences</div>
      <h2 class="section-heading">Traditional DNS vs Handshake.</h2>

      <div class="diff-grid">
        <article class="diff-card">
          <div class="diff-eyebrow">Architecture</div>
          <h3>Centralization vs Decentralization</h3>
          <p>Traditional DNS relies on centralized authorities (ICANN, registrars) while Handshake creates a decentralized root zone managed by blockchain consensus.</p>
        </article>

        <article class="diff-card">
          <div class="diff-eyebrow">Trust model</div>
          <h3>Security Model</h3>
          <p>DNS uses DNSSEC for security, while Handshake leverages blockchain technology and cryptographic proofs for enhanced security.</p>
        </article>

        <article class="diff-card">
          <div class="diff-eyebrow">Ownership</div>
          <h3>Name Ownership</h3>
          <p>Traditional domains are rented through registrars, while Handshake names are truly owned through blockchain-based assets.</p>
        </article>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Going further</div>
      <h2 class="section-heading">Essential resources.</h2>

      <div class="resource-group">
        <h3 class="resource-group-title">Public Resolvers</h3>
        <p class="resource-group-lede">Configure your system to resolve Handshake names.</p>
        <div class="tile-grid tile-grid--2">
          <a href="#" title="Link Offline" onclick="event.preventDefault();" class="link-tile link-tile--offline">
            <h3>HDNS</h3>
            <p>Public Handshake DNS resolver.</p>
            <span class="link-tile-cta">Visit HDNS (Offline)</span>
            <p class="link-tile-original">Original URL: https://www.hdns.io</p>
          </a>
          <a href="#" title="Discontinued" onclick="event.preventDefault();" class="link-tile link-tile--offline">
            <h3>NextDNS</h3>
            <p>DNS resolver with Handshake support.</p>
            <span class="link-tile-cta">Discontinued</span>
            <p class="link-tile-original">Original URL: https://nextdns.io</p>
          </a>
          <a href="https://welcome.hnsdoh.com/" target="_blank" rel="noopener" class="link-tile">
            <h3>HNSDoH</h3>
            <p>Public DNS-over-HTTPS resolver for Handshake.</p>
            <span class="link-tile-cta">Visit HNSDoH &rarr;</span>
          </a>
        </div>
      </div>

      <div class="resource-group">
        <h3 class="resource-group-title">Technical Deep Dives</h3>
        <p class="resource-group-lede">Understanding the technical aspects of Handshake DNS.</p>
        <div class="tile-grid tile-grid--2">
          <a href="https://hsd-dev.org/guides/resource-records.html" target="_blank" rel="noopener" class="link-tile">
            <h3>HNS Resource Records</h3>
            <p>The complete reference for Handshake DNS resource record types.</p>
            <span class="link-tile-cta">Read guide &rarr;</span>
          </a>
          <a href="https://github.com/handshake-org/hsd/blob/master/lib/dns/server.js" target="_blank" rel="noopener" class="link-tile">
            <h3>DNS Implementation</h3>
            <p>Source-level walkthrough of the HSD DNS server.</p>
            <span class="link-tile-cta">View source &rarr;</span>
          </a>
        </div>
      </div>

      <div class="resource-group">
        <h3 class="resource-group-title">Educational Articles</h3>
        <p class="resource-group-lede">Learn more about DNS and Handshake.</p>
        <div class="tile-grid tile-grid--2">
          <a href="/docs/about-handshake/about-handshake" class="link-tile">
            <h3>How Handshake Works</h3>
            <p>Beginner-friendly explainer of the Handshake protocol — preserved in the docs archive.</p>
            <span class="link-tile-cta">Read in docs archive &rarr;</span>
          </a>
          <a href="#" title="Link Offline" onclick="event.preventDefault();" class="link-tile link-tile--offline">
            <h3>What is Handshake DNS?</h3>
            <p>An overview of how Handshake replaces the DNS root.</p>
            <span class="link-tile-cta">Read article (Offline)</span>
            <p class="link-tile-original">Original URL: https://skyinclude.com/what-is-handshake</p>
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .page-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  /* ── Diagram gallery — 1 featured + 5 smaller ── */
  .diagram-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto;
    gap: 1rem;
  }

  .diagram-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .diagram-card:hover {
    transform: translateY(-3px);
    border-color: var(--hns-violet);
    box-shadow: 0 12px 32px rgba(105, 58, 250, 0.1);
    text-decoration: none;
  }

  .diagram-card--featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .diagram-thumb {
    background: var(--aurora-2);
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .diagram-card--featured .diagram-thumb {
    aspect-ratio: auto;
    flex: 1;
    min-height: 320px;
  }

  .diagram-thumb img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0;
    margin: 0;
  }

  .diagram-card > p,
  .diagram-card .diagram-caption {
    padding: 1rem 1.25rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.4;
    margin: 0;
  }

  .diagram-caption p {
    margin: 0;
    color: var(--text-primary);
    font-weight: 500;
    font-size: 0.95rem;
  }

  .diagram-eyebrow {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hns-violet);
    margin-bottom: 0.35rem;
  }

  /* ── Key differences cards ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .diff-card {
    padding: 1.75rem;
    border-radius: 14px;
    background: var(--surface);
    border: 1px solid var(--glass-border);
  }

  .diff-eyebrow {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .diff-card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
  }

  .diff-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Resource groups ── */
  .resource-group { margin-bottom: 2rem; }
  .resource-group:last-child { margin-bottom: 0; }

  .resource-group-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 0.35rem;
    color: var(--text-primary);
  }

  .resource-group-lede {
    color: var(--text-secondary);
    margin: 0 0 1rem;
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .diagram-grid { grid-template-columns: repeat(2, 1fr); }
    .diagram-card--featured { grid-column: span 2; grid-row: auto; }
    .diff-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .diagram-grid { grid-template-columns: 1fr; }
    .diagram-card--featured { grid-column: auto; }
  }
</style>
