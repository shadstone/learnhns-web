---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema, abs } from '../lib/seo';

const description = "Discover the LearnHNS ShakeDex channel. Learn how to buy and sell Handshake (HNS) domains via decentralized marketplace listing proofs.";
---
<BaseLayout
  title="LearnHNS ShakeDex Market Channel"
  description={description}
  keywords="ShakeDex, HNS marketplace, Handshake domain auction, decentralized exchange, listing proofs, atomic swap"
  schema={[
    webPageSchema({ title: 'LearnHNS ShakeDex Market Channel', description, url: abs('/market/') }),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Market', path: '/market/' },
    ]),
  ]}
>
  <div class="page-shell">

    <section class="page-hero">
      <div class="page-hero-eyebrow">Decentralized Exchange</div>
      <h1 class="page-hero-title">
        The LearnHNS <em>Market.</em>
      </h1>
      <p class="page-hero-lede">
        <strong>market.learnhns.com</strong> is our dedicated
        <a href="https://shakedex.org" target="_blank" rel="noopener noreferrer">ShakeDex</a>
        channel marketplace — a non-custodial exchange protocol built directly on the Handshake blockchain.
      </p>
      <div class="hero-cta">
        <a href="https://market.learnhns.com" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Enter market.learnhns.com
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">How it works</div>
      <h2 class="section-heading">A channel, not a custodian.</h2>
      <p class="page-section-lede">
        Unlike traditional centralized exchanges or registrars, ShakeDex is a completely
        decentralized, non-custodial exchange protocol built directly on top of the
        Handshake blockchain. As a "Channel", the LearnHNS Market serves as an indexer
        and user interface designed to distribute and display ShakeDex marketplace
        <strong>listing proofs</strong>.
      </p>

      <div class="feature-tiles">
        <article class="feature-tile">
          <div class="feature-tile-icon">&#9670;</div>
          <h3>Self-Custody</h3>
          <p>You never deposit your HNS coins or domain names into a centralized wallet. Everything remains securely in your own local wallet (like Bob Wallet or the LearnHNS extension).</p>
        </article>

        <article class="feature-tile">
          <div class="feature-tile-icon">&#9650;</div>
          <h3>Listing Proofs</h3>
          <p>When a user lists a Handshake name for sale, they generate a cryptographic "proof" of that listing. Our channel aggregates, organizes, and distributes these proofs so buyers can easily discover them.</p>
        </article>

        <article class="feature-tile">
          <div class="feature-tile-icon">&#9711;</div>
          <h3>Trustless Trading</h3>
          <p>Transactions execute entirely on-chain via atomic swaps (covenants). The ShakeDex protocol ensures the domain name and the funds are exchanged simultaneously — no middleman ever takes custody of your assets.</p>
        </article>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label-row">
        <div class="section-label">Live market data</div>
        <span class="live-dot">Live</span>
      </div>
      <h2 class="section-heading">Latest listings.</h2>
      <p class="page-section-lede">Recent listings fetched directly from the LearnHNS Market API.</p>

      <div id="market-listings" class="listings-grid">
        <p class="loading-text">Loading live listings…</p>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .page-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-cta { margin-top: 2rem; }

  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .feature-tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .feature-tile {
    padding: 1.75rem;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid var(--glass-border);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .feature-tile:hover {
    transform: translateY(-3px);
    border-color: var(--hns-violet);
    box-shadow: 0 12px 32px rgba(105, 58, 250, 0.08);
  }

  .feature-tile-icon {
    font-size: 1.6rem;
    color: var(--hns-violet);
    margin-bottom: 0.85rem;
  }

  .feature-tile h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .feature-tile p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .section-label-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label-row .section-label { margin-bottom: 0; flex: 1; }

  .live-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    color: var(--up-color);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .live-dot::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--up-color);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .listing-card {
    display: block;
    background: #ffffff;
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .listing-card:hover {
    transform: translateY(-3px);
    border-color: var(--hns-violet);
    box-shadow: 0 8px 24px rgba(105, 58, 250, 0.1);
    text-decoration: none;
  }

  .listing-name {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
    word-break: break-all;
  }

  .listing-price {
    font-size: 0.95rem;
    color: var(--hns-violet);
    font-weight: 600;
    margin-bottom: 0.6rem;
  }

  .listing-status {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    display: inline-block;
    font-weight: 700;
  }

  .status-buyable {
    background: rgba(0, 249, 202, 0.18);
    color: var(--up-color);
    border: 1px solid rgba(0, 249, 202, 0.5);
  }

  .status-pending {
    background: rgba(0, 0, 0, 0.04);
    color: var(--text-muted);
    border: 1px solid var(--glass-border);
  }

  .loading-text {
    color: var(--text-muted);
    font-style: italic;
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem;
  }

  @media (max-width: 800px) {
    .feature-tiles { grid-template-columns: 1fr; }
  }
</style>

<script>
  import punycode from 'punycode/';

  async function fetchListings() {
    const container = document.getElementById('market-listings');
    if (!container) return;

    try {
      const response = await fetch('https://market.learnhns.com/api/v2/auctions');
      if (!response.ok) throw new Error('Network response was not ok');

      const data = await response.json();

      if (!data.auctions || data.auctions.length === 0) {
        container.innerHTML = '<p>No listings found.</p>';
        return;
      }

      const latestListings = data.auctions.slice(0, 6);

      container.innerHTML = latestListings.map((listing: any) => {
        const price = listing.expectedPrice ? (listing.expectedPrice / 1000000).toLocaleString() + ' HNS' : 'Make Offer';
        const isBuyable = listing.buyable;
        const statusClass = isBuyable ? 'status-buyable' : 'status-pending';
        const statusText = isBuyable ? 'Buyable' : 'Pending';
        const decodedName = punycode.toUnicode(listing.name);

        return `
          <a href="https://market.learnhns.com/listing/${listing.name}" target="_blank" rel="noopener noreferrer" class="listing-card">
            <div class="listing-name">${decodedName}/</div>
            <div class="listing-price">${price}</div>
            <div class="listing-status ${statusClass}">${statusText}</div>
          </a>
        `;
      }).join('');

    } catch (error) {
      console.error('Error fetching market data:', error);
      container.innerHTML = '<p style="color: var(--down-color); grid-column: 1 / -1; text-align: center;">Failed to load live market data. Please visit the market directly.</p>';
    }
  }

  document.addEventListener('DOMContentLoaded', fetchListings);
</script>
