---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout 
  title="LearnHNS ShakeDex Market Channel" 
  description="Discover the LearnHNS ShakeDex channel. Learn how to buy and sell Handshake (HNS) domains via decentralized marketplace listing proofs."
>
  <div class="content-wrapper">
    <h1>LearnHNS Market</h1>
    
    <div class="card-grid" style="margin-top: 2rem;">
      <section class="card" style="grid-column: 1 / -1;">
        <h2>What is the LearnHNS Market?</h2>
        <p style="font-size: 1.1rem; margin-bottom: 1.5rem;">
          <strong>market.learnhns.com</strong> is our dedicated <a href="https://shakedex.org" target="_blank" rel="noopener noreferrer" style="color: var(--primary-color);">ShakeDex</a> channel marketplace.
        </p>
        
        <p>
          Unlike traditional centralized exchanges or registrars, ShakeDex is a completely decentralized, non-custodial exchange protocol built directly on top of the Handshake blockchain. As a "Channel", the LearnHNS Market serves as an indexer and user interface designed to distribute and display ShakeDex marketplace <strong>listing proofs</strong>.
        </p>
        
        <h3 style="margin-top: 2.5rem; margin-bottom: 1rem;">How it Works</h3>
        <ul style="line-height: 1.8; margin-bottom: 2rem; padding-left: 1.5rem;">
          <li><strong>Self-Custody:</strong> You never deposit your HNS coins or domain names into a centralized wallet. Everything remains securely in your own local wallet (like Bob Wallet or the LearnHNS extension).</li>
          <li><strong>Listing Proofs:</strong> When a user lists a Handshake name for sale, they generate a cryptographic "proof" of that listing. Our channel aggregates, organizes, and distributes these proofs so buyers can easily discover them.</li>
          <li><strong>Trustless Trading:</strong> Transactions are executed entirely on-chain via atomic swaps (covenants). The ShakeDex protocol ensures that the domain name and the funds are exchanged simultaneously without any middleman ever taking custody of your assets.</li>
        </ul>

        <div class="btn-group" style="justify-content: center; margin-top: 3rem;">
          <a href="https://market.learnhns.com" target="_blank" rel="noopener noreferrer" class="btn primary-btn" style="font-size: 1.2rem; padding: 1rem 2.5rem;">Enter market.learnhns.com</a>
        </div>
      </section>

      <section style="grid-column: 1 / -1; margin-top: 2rem;">
        <h2 style="margin-bottom: 0.5rem;">Live Market Data</h2>
        <p style="margin-bottom: 1.5rem; color: #a0aab2;">Here are some of the latest listings fetched directly from the LearnHNS Market API:</p>
        
        <div id="market-listings" class="listings-grid">
          <p class="loading-text">Loading live listings...</p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }
  
  .listing-card {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  
  .listing-card:hover {
    transform: translateY(-3px);
    border-color: var(--primary-color);
  }
  
  .listing-name {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: bold;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    word-break: break-all;
  }
  
  .listing-price {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  
  .listing-status {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    display: inline-block;
  }
  
  .status-buyable {
    background: rgba(16, 185, 129, 0.2);
    color: #34d399;
  }
  
  .status-pending {
    background: rgba(245, 158, 11, 0.2);
    color: #fbbf24;
  }
  
  .loading-text {
    color: #a0aab2;
    font-style: italic;
  }
</style>

<script>
  // A simple punycode decoder since we can't easily use npm modules in a client-side <script> tag natively without a bundler setup.
  // This is a minimal implementation to handle basic emoji domains like xn--on8h9e.
  function decodePunycode(str: string) {
    if (!str.startsWith('xn--')) return str;
    
    // Instead of writing a full punycode decoder from scratch here, 
    // we can use the browser's built-in URL API to decode it!
    try {
      const url = new URL(`http://${str}`);
      return url.hostname;
    } catch (e) {
      return str; // Fallback to raw string if decoding fails
    }
  }

  async function fetchListings() {
    const container = document.getElementById('market-listings');
    if (!container) return;

    try {
      const response = await fetch('https://market.learnhns.com/api/v2/auctions');
      if (!response.ok) throw new Error('Network response was not ok');
      
      const data = await response.json();
      
      if (!data.auctions || data.auctions.length === 0) {
        container.innerHTML = '<p>No listings found.</p>';
        return;
      }

      // Grab the latest 6 listings
      const latestListings = data.auctions.slice(0, 6);
      
      container.innerHTML = latestListings.map((listing: any) => {
        // Convert micro-HNS to HNS (1 HNS = 1,000,000 micro-HNS)
        const price = listing.expectedPrice ? (listing.expectedPrice / 1000000).toLocaleString() + ' HNS' : 'Make Offer';
        
        // Determine status badge styling
        const isBuyable = listing.buyable;
        const statusClass = isBuyable ? 'status-buyable' : 'status-pending';
        const statusText = isBuyable ? 'Buyable' : 'Pending';

        // Decode punycode (e.g. xn--on8h9e -> 🤝)
        const decodedName = decodePunycode(listing.name);

        return `
          <a href="https://market.learnhns.com/listing/${listing.name}" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit;">
            <div class="listing-card card">
              <div class="listing-name">${decodedName}/</div>
              <div class="listing-price">${price}</div>
              <div class="listing-status ${statusClass}">${statusText}</div>
            </div>
          </a>
        `;
      }).join('');
      
    } catch (error) {
      console.error('Error fetching market data:', error);
      container.innerHTML = '<p style="color: #ef4444;">Failed to load live market data. Please visit the market directly.</p>';
    }
  }

  // Fetch when the DOM is fully loaded
  document.addEventListener('DOMContentLoaded', fetchListings);
</script>
