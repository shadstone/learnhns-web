---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="HNS Services - Wallets, Exchanges, and More">
  <div class="content-wrapper">
    <h1>Handshake Services Directory</h1>
    
    <div class="card-grid">
      <section class="card">
        <h2>Wallets</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>Bob Wallet</h3>
            <p>Desktop wallet for managing HNS coins and names</p>
            <a href="https://bobwallet.org" target="_blank" class="btn">Visit Website</a>
          </li>
          <li>
            <h3>Namebase</h3>
            <p>Web-based wallet and name management platform</p>
            <a href="https://www.namebase.io" target="_blank" class="btn">Visit Website</a>
          </li>
          <li>
            <h3>ShakeStation</h3>
            <p>Modern wallet and name management interface</p>
            <a href="#" title="Link Offline" style="opacity: 0.5; cursor: not-allowed;" onclick="event.preventDefault();" target="_blank" class="btn">Visit Website (Offline)</a>
            <p style="font-size: 0.8rem; margin-top: 0.5rem; opacity: 0.7; word-break: break-all;">Original URL: https://shakestation.io</p>
          </li>
          <li>
            <h3>HNS Ledger App</h3>
            <p>Hardware wallet support for Ledger devices</p>
            <a href="https://github.com/handshake-org/ledger-app-hns" target="_blank" class="btn">Learn More</a>
          </li>
        </ul>
      </section>

      <section class="card">
        <h2>Exchanges</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>Namebase Exchange</h3>
            <p>Buy, sell, and trade HNS</p>
            <a href="#" title="Link Offline" style="opacity: 0.5; cursor: not-allowed;" onclick="event.preventDefault();" target="_blank" class="btn">Trade Now (Offline)</a>
            <p style="font-size: 0.8rem; margin-top: 0.5rem; opacity: 0.7; word-break: break-all;">Original URL: https://www.namebase.io/exchange</p>
          </li>
          <li>
            <h3>Gate.io</h3>
            <p>HNS trading pairs available</p>
            <a href="https://gate.io" target="_blank" class="btn">Trade Now</a>
          </li>
        </ul>
      </section>

      <section class="card">
        <h2>Mining Pools</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>6Block Pool</h3>
            <p>Professional HNS mining pool</p>
            <a href="https://6block.com" target="_blank" class="btn">Start Mining</a>
          </li>
          <li>
            <h3>F2Pool</h3>
            <p>Multi-currency mining pool supporting HNS</p>
            <a href="https://www.f2pool.com" target="_blank" class="btn">Start Mining</a>
          </li>
        </ul>
      </section>

      <section class="card">
        <h2>Name Services</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>Namebase Registry</h3>
            <p>Register and manage Handshake domains</p>
            <a href="#" title="Link Offline" style="opacity: 0.5; cursor: not-allowed;" onclick="event.preventDefault();" target="_blank" class="btn">Register Names (Offline)</a>
            <p style="font-size: 0.8rem; margin-top: 0.5rem; opacity: 0.7; word-break: break-all;">Original URL: https://www.namebase.io/domains</p>
          </li>
          <li>
            <h3>HNS.ID</h3>
            <p>Handshake name lookup and management</p>
            <a href="https://hns.id" target="_blank" class="btn">Search Names</a>
          </li>
        </ul>
      </section>

      <section class="card">
        <h2>Developer Tools</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>HSD</h3>
            <p>Full node implementation and wallet</p>
            <a href="https://github.com/handshake-org/hsd" target="_blank" class="btn">View Repository</a>
          </li>
          <li>
            <h3>HNSD</h3>
            <p>Light client for Handshake</p>
            <a href="https://github.com/handshake-org/hnsd" target="_blank" class="btn">View Repository</a>
          </li>
        </ul>
      </section>

      <section class="card">
        <h2>Resolvers</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>HDNS</h3>
            <p>Public Handshake DNS resolver</p>
            <a href="#" title="Link Offline" style="opacity: 0.5; cursor: not-allowed;" onclick="event.preventDefault();" target="_blank" class="btn">Configure Now (Offline)</a>
            <p style="font-size: 0.8rem; margin-top: 0.5rem; opacity: 0.7; word-break: break-all;">Original URL: https://www.hdns.io</p>
          </li>
          <li>
            <h3>NextDNS</h3>
            <p>DNS resolver with Handshake support</p>
            <a href="https://nextdns.io" target="_blank" class="btn">Configure Now</a>
          </li>
        </ul>
      </section>

      <section class="card">
        <h2>Block Explorers</h2>
        <ul class="resource-list" style="grid-template-columns: 1fr;">
          <li>
            <h3>HNSFans Explorer</h3>
            <p>Comprehensive Handshake blockchain explorer</p>
            <a href="https://e.hnsfans.com" target="_blank" class="btn">View Explorer</a>
          </li>
          <li>
            <h3>ShakeShift</h3>
            <p>Modern Handshake block and name explorer</p>
            <a href="https://shakeshift.com" target="_blank" class="btn">View Explorer</a>
          </li>
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>
