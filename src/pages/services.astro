---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, collectionPageSchema, abs } from '../lib/seo';

const description = "A complete directory of Handshake (HNS) services including desktop wallets, mining pools, exchanges, and block explorers.";
---
<BaseLayout
  title="HNS Services - Wallets, Exchanges, and More"
  description={description}
  keywords="HNS wallets, Bob Wallet, ShakeStation, HNS Ledger, HNS mining pool, HNS exchange, HNS resolver, NextDNS, HDNS"
  schema={[
    collectionPageSchema({ title: 'Handshake Services Directory', description, url: abs('/services/') }),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Services', path: '/services/' },
    ]),
  ]}
>
  <div class="page-shell">

    <section class="page-hero">
      <div class="page-hero-eyebrow">Ecosystem Directory</div>
      <h1 class="page-hero-title">
        Handshake <em>services.</em>
      </h1>
      <p class="page-hero-lede">
        Wallets, exchanges, mining pools, name services, developer tooling, resolvers,
        and explorers — the working ecosystem around HNS, organized so you can
        actually find what you need.
      </p>
    </section>

    <section class="page-section">
      <div class="section-label">Wallets</div>
      <div class="tile-grid tile-grid--4">
        <a href="https://bobwallet.org" target="_blank" rel="noopener" class="link-tile">
          <h3>Bob Wallet</h3>
          <p>Desktop wallet for managing HNS coins and names.</p>
          <span class="link-tile-cta">Visit website &rarr;</span>
        </a>
        <a href="#" title="Service Closed" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>Namebase</h3>
          <p>Web-based wallet and name management platform. Closed June 2026.</p>
          <span class="link-tile-cta">Service closed</span>
          <p class="link-tile-original">Original URL: https://www.namebase.io</p>
        </a>
        <a href="#" title="Link Offline" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>ShakeStation</h3>
          <p>Modern wallet and name management interface.</p>
          <span class="link-tile-cta">Visit website (Offline)</span>
          <p class="link-tile-original">Original URL: https://shakestation.io</p>
        </a>
        <a href="https://github.com/handshake-org/ledger-app-hns" target="_blank" rel="noopener" class="link-tile">
          <h3>HNS Ledger App</h3>
          <p>Hardware wallet support for Ledger devices.</p>
          <span class="link-tile-cta">Learn more &rarr;</span>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Exchanges</div>
      <div class="tile-grid tile-grid--3">
        <a href="https://liquidity.spot" target="_blank" rel="noopener" class="link-tile">
          <h3>Liquidity Spot</h3>
          <p>P2P HNS trading and experimental BTC atomic swaps.</p>
          <span class="link-tile-cta">Trade now &rarr;</span>
        </a>
        <a href="https://www.coinex.com" target="_blank" rel="noopener" class="link-tile">
          <h3>CoinEx</h3>
          <p>Centralized exchange with HNS spot trading.</p>
          <span class="link-tile-cta">Trade now &rarr;</span>
        </a>
        <a href="https://www.mexc.com" target="_blank" rel="noopener" class="link-tile">
          <h3>MEXC</h3>
          <p>Centralized exchange with HNS spot trading.</p>
          <span class="link-tile-cta">Trade now &rarr;</span>
        </a>
        <a href="#" title="Service Closed" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>Namebase Exchange</h3>
          <p>Former HNS onramp. Closed June 2026.</p>
          <span class="link-tile-cta">Service closed</span>
          <p class="link-tile-original">Original URL: https://www.namebase.io/exchange</p>
        </a>
        <a href="#" title="Delisted" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>Gate.io</h3>
          <p>HNS no longer listed.</p>
          <span class="link-tile-cta">Delisted</span>
          <p class="link-tile-original">Original URL: https://gate.io</p>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Mining pools</div>
      <div class="tile-grid tile-grid--3">
        <a href="https://6block.com" target="_blank" rel="noopener" class="link-tile">
          <h3>6Block Pool</h3>
          <p>Professional HNS mining pool.</p>
          <span class="link-tile-cta">Start mining &rarr;</span>
        </a>
        <a href="https://www.f2pool.com" target="_blank" rel="noopener" class="link-tile">
          <h3>F2Pool</h3>
          <p>Multi-currency mining pool supporting HNS.</p>
          <span class="link-tile-cta">Start mining &rarr;</span>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Name services</div>
      <div class="tile-grid tile-grid--3">
        <a href="#" title="Link Offline" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>Namebase Registry</h3>
          <p>Register and manage Handshake domains.</p>
          <span class="link-tile-cta">Register names (Offline)</span>
          <p class="link-tile-original">Original URL: https://www.namebase.io/domains</p>
        </a>
        <a href="https://hns.id" target="_blank" rel="noopener" class="link-tile">
          <h3>HNS.ID</h3>
          <p>Handshake name lookup and management.</p>
          <span class="link-tile-cta">Search names &rarr;</span>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Developer tools</div>
      <div class="tile-grid tile-grid--3">
        <a href="https://github.com/handshake-org/hsd" target="_blank" rel="noopener" class="link-tile">
          <h3>HSD</h3>
          <p>Full node implementation and wallet.</p>
          <span class="link-tile-cta">View repository &rarr;</span>
        </a>
        <a href="https://github.com/handshake-org/hnsd" target="_blank" rel="noopener" class="link-tile">
          <h3>HNSD</h3>
          <p>Light client for Handshake.</p>
          <span class="link-tile-cta">View repository &rarr;</span>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Resolvers</div>
      <div class="tile-grid tile-grid--3">
        <a href="#" title="Link Offline" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>HDNS</h3>
          <p>Public Handshake DNS resolver.</p>
          <span class="link-tile-cta">Configure now (Offline)</span>
          <p class="link-tile-original">Original URL: https://www.hdns.io</p>
        </a>
        <a href="#" title="Discontinued" onclick="event.preventDefault();" class="link-tile link-tile--offline">
          <h3>NextDNS</h3>
          <p>DNS resolver with Handshake support.</p>
          <span class="link-tile-cta">Discontinued</span>
          <p class="link-tile-original">Original URL: https://nextdns.io</p>
        </a>
        <a href="https://welcome.hnsdoh.com/" target="_blank" rel="noopener" class="link-tile">
          <h3>HNSDoH</h3>
          <p>Public DNS-over-HTTPS resolver for Handshake.</p>
          <span class="link-tile-cta">Visit HNSDoH &rarr;</span>
        </a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-label">Block explorers</div>
      <div class="tile-grid tile-grid--3">
        <a href="https://e.hnsfans.com" target="_blank" rel="noopener" class="link-tile">
          <h3>HNSFans Explorer</h3>
          <p>Comprehensive Handshake blockchain explorer.</p>
          <span class="link-tile-cta">View explorer &rarr;</span>
        </a>
        <a href="https://shakeshift.com" target="_blank" rel="noopener" class="link-tile">
          <h3>ShakeShift</h3>
          <p>Modern Handshake block and name explorer.</p>
          <span class="link-tile-cta">View explorer &rarr;</span>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .page-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Tighter vertical rhythm — many small sections back to back */
  .page-section { padding: 1.75rem 0 2.5rem; }
  .page-section:last-child { padding-bottom: 5rem; }
</style>
