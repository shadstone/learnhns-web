---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Handshake (HNS) Podcasts & Videos" description="Watch videos and listen to podcasts featuring interviews and deep dives into the Handshake (HNS) decentralized DNS ecosystem.">
  <div class="content-wrapper">
    <h1>Educational Podcasts and Videos</h1>
    <div class="content">
      <div class="video-section" style="margin-bottom: 3rem;">
        <h2>Featured Videos</h2>
        <ul class="resource-list">
          <li>
            <h3>Handshake Overview by Namebase</h3>
            <a href="https://www.youtube.com/watch?v=tB0RWxBNKnE" target="_blank" class="btn">Watch Video</a>
          </li>
          <li>
            <h3>What is Handshake? HNS Explained</h3>
            <a href="https://www.youtube.com/watch?v=tB0RWxBNKnE" target="_blank" class="btn">Watch Video</a>
          </li>
        </ul>
      </div>
      
      <div class="podcast-section">
        <h2>Podcast Episodes</h2>
        <ul class="resource-list">
          <li>
            <h3>Handshake on The Breakdown with NLW</h3>
            <a href="https://www.coindesk.com/podcasts/the-breakdown-with-nlw/" target="_blank" class="btn">Listen Now</a>
          </li>
          <li>
            <h3>Handshake: A Decentralized DNS with Devon James</h3>
            <a href="#" title="Link Offline" style="opacity: 0.5; cursor: not-allowed;" onclick="event.preventDefault();" target="_blank" class="btn">Listen Now (Offline)</a>
            <p style="font-size: 0.8rem; margin-top: 0.5rem; opacity: 0.7; word-break: break-all;">Original URL: https://podcasts.apple.com/us/podcast/off-the-chain/</p>
          </li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
