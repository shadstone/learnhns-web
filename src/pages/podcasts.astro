---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Educational Podcasts and Videos">
  <div class="content-wrapper">
    <h1>Educational Podcasts and Videos</h1>
    <div class="content">
      <div class="video-section" style="margin-bottom: 3rem;">
        <h2>Featured Videos</h2>
        <ul class="resource-list">
          <li>
            <h3>Handshake Overview by Namebase</h3>
            <a href="https://www.youtube.com/watch?v=tB0RWxBNKnE" target="_blank" class="btn">Watch Video</a>
          </li>
          <li>
            <h3>What is Handshake? HNS Explained</h3>
            <a href="https://www.youtube.com/watch?v=tB0RWxBNKnE" target="_blank" class="btn">Watch Video</a>
          </li>
        </ul>
      </div>
      
      <div class="podcast-section">
        <h2>Podcast Episodes</h2>
        <ul class="resource-list">
          <li>
            <h3>Handshake on The Breakdown with NLW</h3>
            <a href="https://www.coindesk.com/podcasts/the-breakdown-with-nlw/" target="_blank" class="btn">Listen Now</a>
          </li>
          <li>
            <h3>Handshake: A Decentralized DNS with Devon James</h3>
            <a href="https://podcasts.apple.com/us/podcast/off-the-chain/" target="_blank" class="btn">Listen Now</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
