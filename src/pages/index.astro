---
import BaseLayout from '../layouts/BaseLayout.astro';
import { organizationSchema, websiteSchema } from '../lib/seo';
---
<BaseLayout
  title="Your Gateway to Understanding Handshake"
  description="LearnHNS curates the best guides, wallets, tutorials, and community resources for the Handshake decentralized naming protocol. Whether you've never heard of HNS or you're ready to run a full node — start here."
  keywords="Handshake, HNS, decentralized DNS, blockchain naming, top-level domains, TLD, Bob Wallet, ShakeDex, decentralized internet"
  schema={[organizationSchema(), websiteSchema()]}
>
  <!-- LIVE TICKER -->
  <div class="ticker-wrap">
    <div class="ticker-label">Live</div>
    <div class="ticker-viewport">
      <div class="ticker-track" id="learnhns-ticker-track">
        <span class="ticker-item"><span class="ticker-name">market.learnhns.com</span><span class="ticker-price">live auctions</span></span>
        <span class="ticker-item"><span class="ticker-name">loading…</span></span>
        <span class="ticker-item"><span class="ticker-name">market.learnhns.com</span><span class="ticker-price">live auctions</span></span>
        <span class="ticker-item"><span class="ticker-name">loading…</span></span>
      </div>
    </div>
  </div>

  <div class="home-shell">

    <!-- HERO -->
    <section class="home-hero">
      <svg class="hero-network" viewBox="0 0 1000 500" aria-hidden="true">
        <g class="net-lines">
          <line class="net-line" x1="120" y1="120" x2="320" y2="220" />
          <line class="net-line" x1="120" y1="120" x2="280" y2="380" />
          <line class="net-line" x1="320" y1="220" x2="500" y2="100" />
          <line class="net-line" x1="320" y1="220" x2="500" y2="340" />
          <line class="net-line" x1="320" y1="220" x2="280" y2="380" />
          <line class="net-line" x1="500" y1="100" x2="680" y2="240" />
          <line class="net-line" x1="500" y1="340" x2="680" y2="240" />
          <line class="net-line" x1="500" y1="340" x2="720" y2="400" />
          <line class="net-line" x1="680" y1="240" x2="880" y2="160" />
          <line class="net-line" x1="680" y1="240" x2="860" y2="380" />
          <line class="net-line" x1="280" y1="380" x2="500" y2="340" />
          <line class="net-line" x1="880" y1="160" x2="860" y2="380" />
        </g>
        <g class="net-nodes">
          <circle class="net-node net-node--pulse" cx="120" cy="120" r="4" />
          <circle class="net-node" cx="320" cy="220" r="6" />
          <circle class="net-node net-node--pulse" cx="500" cy="100" r="4" />
          <circle class="net-node" cx="500" cy="340" r="5" />
          <circle class="net-node net-node--pulse" cx="680" cy="240" r="6" />
          <circle class="net-node" cx="280" cy="380" r="4" />
          <circle class="net-node net-node--pulse" cx="880" cy="160" r="4" />
          <circle class="net-node" cx="860" cy="380" r="4" />
          <circle class="net-node net-node--pulse" cx="720" cy="400" r="3" />
        </g>
      </svg>
      <div class="hero-eyebrow">Handshake Protocol &mdash; Education Hub</div>
      <h1 class="hero-title">
        Your gateway to<br />
        <em>understanding Handshake.</em>
      </h1>
      <p class="hero-lead">
        LearnHNS curates the best guides, wallets, tutorials, and community
        resources for the Handshake decentralized naming protocol. Whether
        you've never heard of HNS or you're ready to run a full node — start here.
      </p>
      <div class="hero-actions">
        <a href="/start/" class="btn-primary">
          Start Learning
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/market/" class="btn-secondary">Browse Marketplace</a>
      </div>
    </section>

    <!-- WHERE TO BEGIN — three learning paths -->
    <section class="learning-paths">
      <div class="section-label">Where to begin</div>

      <div class="paths-grid">
        <a href="/start/" class="path-card path-card-1">
          <span class="path-icon" aria-hidden="true">&#9654;</span>
          <div class="path-label">Start here</div>
          <h3>Getting Started</h3>
          <p class="path-tagline">New to Handshake? Start here.</p>
          <p>Zero to first domain in one afternoon. Wallet setup, bidding, resolving — the complete beginner path for anyone curious about owning a piece of the internet.</p>
          <span class="path-arrow" aria-hidden="true">&#8599;</span>
        </a>

        <a href="/learn/" class="path-card path-card-2">
          <span class="path-icon" aria-hidden="true">&#9670;</span>
          <div class="path-label">Go deeper</div>
          <h3>Learn the Protocol</h3>
          <p class="path-tagline">How HNS, DNS, and decentralized name resolution actually work.</p>
          <p>Deep dives on the Handshake blockchain, the auction mechanism, DNSSEC, resolvers, and why this matters for the future of the internet.</p>
          <span class="path-arrow" aria-hidden="true">&#8599;</span>
        </a>

        <a href="/media/" class="path-card path-card-3">
          <span class="path-icon" aria-hidden="true">&#9711;</span>
          <div class="path-label">Explore the ecosystem</div>
          <h3>Media &amp; Tools</h3>
          <p class="path-tagline">Podcasts, articles, wallets, and services curated for the ecosystem.</p>
          <p>The best HNS podcasts, long-form articles, wallet comparisons, and community services. Everything you need to stay current and get things done.</p>
          <span class="path-arrow" aria-hidden="true">&#8599;</span>
        </a>
      </div>
    </section>

    <!-- WHAT IS HANDSHAKE -->
    <section class="explainer">
      <div class="section-label section-label-teal">The Protocol</div>
      <div class="explainer-grid">
        <div>
          <h2>The internet's namespace,<br /><em>finally decentralized.</em></h2>
          <p>
            For decades, the domain name system has been controlled by a handful of
            organizations — primarily ICANN — who decide which top-level domains
            exist, who can register them, and how much you pay every year to keep
            them. Your domain isn't yours; it's a rental.
          </p>
          <p>
            Handshake changes the root. By recording TLD ownership on a proof-of-work
            blockchain, it creates a naming system where you hold the keys — not a
            registrar. Resolve names with a compatible browser or resolver, and your
            domain works across the decentralized web forever.
          </p>
          <p>
            LearnHNS curates the best tools, tutorials, wallets, and marketplaces so
            you can get from zero to sovereign in an afternoon.
          </p>
        </div>
        <div>
          <div class="dns-diagram">
            <p class="diagram-title">Traditional vs. Handshake DNS</p>
            <div class="diagram-row">
              <div class="diagram-node node-icann">ICANN Root</div>
              <div class="diagram-arrow">&rarr;</div>
              <div class="diagram-node node-icann">Registrar</div>
              <div class="diagram-arrow">&rarr;</div>
              <div class="diagram-node node-user">You (Renter)</div>
            </div>
            <p class="diagram-label">Old way — you pay annually, they can revoke</p>
            <div class="diagram-row">
              <div class="diagram-node node-hns">HNS Blockchain</div>
              <div class="diagram-arrow">&rarr;</div>
              <div class="diagram-node node-hns">Your Wallet</div>
              <div class="diagram-arrow">&rarr;</div>
              <div class="diagram-node node-user node-user--owner">You (Owner)</div>
            </div>
            <p class="diagram-label">New way — cryptographic ownership, forever</p>
          </div>
          <div class="stats-row">
            <div class="stat-item">
              <div class="stat-number">4M+</div>
              <div class="stat-label">Names Registered</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">$0</div>
              <div class="stat-label">Annual Renewal</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">100%</div>
              <div class="stat-label">Permissionless</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LIVE AUCTIONS STRIP -->
    <section class="auctions-strip">
      <div class="auctions-strip-head">
        <div class="section-label section-label-teal auctions-label">Live Auctions &mdash; the ecosystem is alive</div>
        <span class="live-dot">Live</span>
        <a href="https://market.learnhns.com" class="strip-link" target="_blank" rel="noopener">View all auctions &rarr;</a>
      </div>

      <div class="auctions-row" id="learnhns-auctions">
        <div class="strip-loading">Loading live auction data…</div>
      </div>
    </section>

    <!-- RESOURCES -->
    <section class="resources">
      <div class="section-label">Start Exploring</div>
      <h2>Everything you need,<br />in one place.</h2>
      <p class="resources-lead">Pick where to dive in. Each path is built for a different level of familiarity.</p>

      <div class="resource-grid">
        <a href="/start/" class="resource-card resource-card-r1">
          <span class="resource-icon" aria-hidden="true">&#9654;</span>
          <h3>Getting Started</h3>
          <p>Zero to first domain in 20 minutes. The absolute beginner path.</p>
          <span class="resource-arrow" aria-hidden="true">&#8599;</span>
        </a>
        <a href="/services/" class="resource-card resource-card-r2">
          <span class="resource-icon" aria-hidden="true">&#9670;</span>
          <h3>Wallets</h3>
          <p>Bob Wallet, Namebase, Firefly — find the one that fits how you work.</p>
          <span class="resource-arrow" aria-hidden="true">&#8599;</span>
        </a>
        <a href="/market/" class="resource-card resource-card-r3">
          <span class="resource-icon" aria-hidden="true">&#9652;</span>
          <h3>Marketplaces</h3>
          <p>Buy, sell, and auction TLDs. SHAKEDEX, Namebase secondary, and more.</p>
          <span class="resource-arrow" aria-hidden="true">&#8599;</span>
        </a>
        <a href="/podcasts/" class="resource-card resource-card-r4">
          <span class="resource-icon" aria-hidden="true">&#9711;</span>
          <h3>Podcasts</h3>
          <p>Deep dives with builders, founders, and early adopters in the HNS ecosystem.</p>
          <span class="resource-arrow" aria-hidden="true">&#8599;</span>
        </a>
        <a href="/learn/" class="resource-card resource-card-r5">
          <span class="resource-icon" aria-hidden="true">&#9632;</span>
          <h3>Tutorials</h3>
          <p>How to resolve HNS domains, set up DNSSEC, and build on Handshake.</p>
          <span class="resource-arrow" aria-hidden="true">&#8599;</span>
        </a>
      </div>
    </section>

  </div>

</BaseLayout>

<style>
  /* ── Layout shell ── */
  .home-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Ticker ── */
  .ticker-wrap {
    overflow: hidden;
    border-bottom: 1px solid var(--glass-border);
    background: rgba(0, 0, 0, 0.02);
    height: 36px;
    display: flex;
    align-items: center;
  }

  .ticker-label {
    flex-shrink: 0;
    padding: 0 1rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hns-violet);
    border-right: 1px solid var(--glass-border);
    height: 100%;
    display: flex;
    align-items: center;
    background: rgba(105, 58, 250, 0.04);
  }

  .ticker-viewport { overflow: hidden; flex: 1; }

  .ticker-track {
    display: flex;
    gap: 3rem;
    animation: ticker 28s linear infinite;
    white-space: nowrap;
    padding-left: 2rem;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* Ticker items are created by JS via innerHTML, so they don't carry
     Astro's scope attribute. Use :global() so the styles apply anyway. */
  :global(.ticker-item) {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.65rem;
    font-weight: 500;
    line-height: 1;
  }

  :global(.ticker-name) {
    color: var(--text-primary);
    font-family: var(--font-mono);
  }
  :global(.ticker-price) { color: var(--text-secondary); }

  :global(.ticker-status-buyable),
  :global(.ticker-status-pending) {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-left: 0.25rem;
  }

  :global(.ticker-status-buyable) { color: var(--up-color); }
  :global(.ticker-status-pending) { color: var(--text-muted); }

  /* ── Hero ── */
  .home-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 0 5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-network {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 130%;
    max-width: 1100px;
    height: auto;
    transform: translate(-50%, -52%);
    pointer-events: none;
    opacity: 0.5;
    z-index: 0;
    mix-blend-mode: multiply;
  }

  .hero-network .net-line {
    stroke: #000;
    stroke-width: 1;
    stroke-opacity: 0.25;
    fill: none;
  }

  .hero-network .net-node { fill: #000; }

  .hero-network .net-node--pulse {
    animation: nodePulse 3s ease-in-out infinite;
    transform-origin: center;
  }
  .hero-network .net-node--pulse:nth-child(2) { animation-delay: 0.6s; }
  .hero-network .net-node--pulse:nth-child(3) { animation-delay: 1.2s; }
  .hero-network .net-node--pulse:nth-child(4) { animation-delay: 1.8s; }
  .hero-network .net-node--pulse:nth-child(5) { animation-delay: 2.4s; }

  @keyframes nodePulse {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 1; }
  }

  .hero-eyebrow {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hns-violet);
    margin-bottom: 1.5rem;
  }

  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--hns-violet);
  }

  .hero-title {
    position: relative;
    z-index: 2;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 5.25rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    background: none;
    -webkit-background-clip: initial;
    -webkit-text-fill-color: initial;
  }

  .hero-title em {
    font-style: italic;
    color: var(--hns-violet);
  }

  .hero-lead {
    position: relative;
    z-index: 2;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 2.25rem;
    font-weight: 400;
  }

  .hero-actions {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Section labels ── */
  .section-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hns-violet);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(105, 58, 250, 0.4), transparent);
  }

  /* ── Learning paths ── */
  .learning-paths { padding: 0 0 5rem; }

  .paths-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .path-card {
    position: relative;
    display: block;
    padding: 2rem;
    border-radius: 16px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.14);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .path-card:hover {
    transform: translateY(-5px);
    border-color: var(--hns-violet);
    box-shadow: 0 12px 36px rgba(105, 58, 250, 0.1);
    text-decoration: none;
  }

  .path-icon {
    display: block;
    font-size: 1.85rem;
    color: var(--hns-violet);
    margin-bottom: 1.1rem;
  }

  .path-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }

  .path-card h3 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .path-tagline {
    font-size: 0.9rem;
    color: var(--hns-violet);
    font-weight: 500;
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .path-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 400;
  }

  .path-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: transform 0.2s, color 0.2s;
  }

  .path-card:hover .path-arrow {
    transform: translate(3px, -3px);
    color: var(--hns-violet);
  }

  /* ── Explainer ── */
  .explainer { padding: 5rem 0; }

  .explainer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .explainer h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.4vw, 3rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .explainer h2 em {
    font-style: italic;
    color: var(--hns-violet);
  }

  .explainer p {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 0.98rem;
    font-weight: 400;
    margin-bottom: 1.1rem;
  }

  /* DNS diagram */
  .dns-diagram {
    padding: 1.75rem;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid var(--glass-border);
  }

  .diagram-title {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.1rem;
  }

  .diagram-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .diagram-node {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 500;
  }

  .node-icann {
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.15);
    color: rgba(0, 0, 0, 0.5);
    text-decoration: line-through;
  }

  .node-hns {
    background: rgba(105, 58, 250, 0.08);
    border: 1px solid rgba(105, 58, 250, 0.3);
    color: var(--hns-violet);
  }

  .node-user {
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.15);
    color: rgba(0, 0, 0, 0.7);
  }

  .node-user--owner {
    background: rgba(0, 249, 202, 0.12);
    border-color: rgba(0, 249, 202, 0.4);
    color: var(--up-color);
  }

  .diagram-arrow {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .diagram-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-left: 0.25rem;
    margin-bottom: 1.1rem;
  }

  .diagram-label:last-of-type { margin-bottom: 0; }

  .stats-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .stat-item {
    padding: 1rem;
    border-radius: 10px;
    text-align: center;
    background: #ffffff;
    border: 1px solid var(--glass-border);
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.62rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Auctions strip ── */
  .auctions-strip { padding: 3rem 0 2rem; }

  .auctions-strip-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .auctions-label { margin: 0; flex: 1; min-width: 200px; }

  .live-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    color: var(--up-color);
    font-weight: 500;
  }

  .live-dot::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--up-color);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.7); }
  }

  .strip-link {
    font-size: 0.75rem;
    color: var(--hns-violet);
    text-decoration: none;
    transition: color 0.2s;
  }

  .strip-link:hover { color: var(--hns-violet-deep); text-decoration: underline; }

  .auctions-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
    padding: 1.25rem;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid var(--glass-border);
  }

  .auction-card {
    display: block;
    padding: 1rem;
    border-radius: 10px;
    background: #ffffff;
    border: 1px solid var(--glass-border);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    min-width: 0;
  }

  .auction-card:hover {
    transform: translateY(-3px);
    border-color: var(--hns-violet);
    box-shadow: 0 8px 24px rgba(105, 58, 250, 0.1);
    text-decoration: none;
  }

  .auction-tld {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .auction-price {
    font-size: 0.8rem;
    color: var(--hns-violet);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .auction-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .badge {
    font-size: 0.55rem;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .badge-buyable {
    background: rgba(0, 249, 202, 0.18);
    color: var(--up-color);
    border: 1px solid rgba(0, 249, 202, 0.5);
  }

  .badge-pending {
    background: rgba(0, 0, 0, 0.04);
    color: var(--text-muted);
    border: 1px solid rgba(0, 0, 0, 0.12);
  }

  .auction-bids {
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  .strip-loading,
  .strip-error {
    grid-column: 1 / -1;
    text-align: center;
    padding: 1.5rem;
    font-size: 0.85rem;
  }
  .strip-loading { color: var(--text-muted); }
  .strip-error { color: var(--down-color); }
  .strip-error a { color: var(--hns-violet); }

  /* ── Resources ── */
  .resources { padding: 3rem 0 6rem; }

  .resources h2 {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
    color: var(--text-primary);
  }

