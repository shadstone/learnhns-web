  /* ── Responsive ── */
  @media (max-width: 900px) {
    .home-shell { padding: 0 1.25rem; }
    .home-hero { padding: 4rem 0 3rem; min-height: 60vh; }
    .paths-grid { grid-template-columns: 1fr; gap: 1rem; }
    .explainer-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .resource-grid { grid-template-columns: repeat(2, 1fr); }
    .auctions-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .resource-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: 1fr; }
    .auctions-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Live auction data — populates ticker + 5-card strip.
  let punyDecode: (s: string) => string = (s) => s;
  try {
    const mod = await import('https://unpkg.com/punycode@2.3.1/punycode.es6.js');
    // @ts-ignore — CDN-loaded ESM, no types
    if (mod && typeof mod.toUnicode === 'function') punyDecode = mod.toUnicode;
  } catch (e) {
    console.warn('[LearnHNS] punycode CDN unavailable, using raw names', e);
  }

  function formatPrice(expectedPrice: number | null | undefined): string {
    if (!expectedPrice) return 'Make Offer';
    return (expectedPrice / 1_000_000).toLocaleString() + ' HNS';
  }

  async function loadAuctions(): Promise<void> {
    const auctionsEl = document.getElementById('learnhns-auctions');
    const tickerTrack = document.getElementById('learnhns-ticker-track');
    if (!auctionsEl || !tickerTrack) return;

    try {
      const res = await fetch('https://market.learnhns.com/api/v2/auctions');
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();

      const listings = (data.auctions || []).slice(0, 5);
      if (!listings.length) throw new Error('empty');

      auctionsEl.innerHTML = listings.map((listing: any) => {
        const name = punyDecode(listing.name) + '/';
        const price = formatPrice(listing.expectedPrice);
        const isBuyable = listing.buyable === true;
        const badgeClass = isBuyable ? 'badge-buyable' : 'badge-pending';
        const badgeText = isBuyable ? 'Buyable' : 'Pending';
        const bids = listing.bids?.length || 0;
        const url = `https://market.learnhns.com/listing/${listing.name}`;

        return `
          <a href="${url}" target="_blank" rel="noopener noreferrer" class="auction-card">
            <div class="auction-tld">${name}</div>
            <div class="auction-price">${price}</div>
            <div class="auction-meta-row">
              <span class="badge ${badgeClass}">${badgeText}</span>
              <span class="auction-bids">${bids} bid${bids !== 1 ? 's' : ''}</span>
            </div>
          </a>
        `;
      }).join('');

      const tickerItems = listings.map((listing: any) => {
        const name = punyDecode(listing.name) + '/';
        const price = formatPrice(listing.expectedPrice);
        const isBuyable = listing.buyable === true;
        const statusClass = isBuyable ? 'ticker-status-buyable' : 'ticker-status-pending';
        const statusText = isBuyable ? 'Buyable' : 'Pending';
        return `<span class="ticker-item"><span class="ticker-name">${name}</span><span class="ticker-price">${price}</span><span class="${statusClass}">${statusText}</span></span>`;
      }).join('');
      tickerTrack.innerHTML = tickerItems + tickerItems;

    } catch (err) {
      console.warn('[LearnHNS] Market data unavailable:', err);
      auctionsEl.innerHTML = `
        <div class="strip-error">
          Live market data unavailable. <a href="https://market.learnhns.com" target="_blank" rel="noopener">View directly &rarr;</a>
        </div>
      `;
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadAuctions);
  } else {
    loadAuctions();
  }
</script>
