---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Your Gateway to Handshake Resources">
  <section class="hero video-hero">
    <img src="/learnhns-animated.svg" class="hero-bg-video" alt="LearnHNS Animation" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Your gateway to the best Handshake resources</h1>
      <p class="hero-text">LearnHNS is your gateway to exploring the future of decentralized domains. We're curating the best resources and guides to help you understand and navigate Handshake (HNS), a revolutionary decentralized domain name system. Whether you're new to Handshake or looking to deepen your knowledge, LearnHNS provides everything you need to unlock the potential of internet freedom.</p>
    </div>
  </section>

  <section class="featured-sections card-grid">
    <div class="feature-card card">
      <h2>Getting Started</h2>
      <p>New to Handshake? Start here to learn the basics and understand how HNS is revolutionizing domain names.</p>
      <a href="/learn/" class="btn">Learn More</a>
    </div>
    
    <div class="feature-card card">
      <h2>Educational Content</h2>
      <p>Explore our curated collection of articles, videos, and podcasts about Handshake and decentralized DNS.</p>
      <a href="/media/" class="btn">Browse Resources</a>
    </div>
    
    <div class="feature-card card">
      <h2>Tools & Services</h2>
      <p>Find the best wallets, exchanges, and services to start using Handshake domains today.</p>
      <a href="/services/" class="btn">View Services</a>
    </div>
  </section>
</BaseLayout>
