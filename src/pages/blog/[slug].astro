---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreWithAI from '../../components/ExploreWithAI.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { abs, blogPostingSchema, breadcrumbSchema, parseCrawlerSignal } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'posts'> };
const { post } = Astro.props as Props;
const { data } = post;

const dateLabel = data.created_at
  ? new Date(data.created_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const postUrl = abs(`/blog/${post.id}/`);
const canonicalUrl = data.seo?.canonical_url || postUrl;

// Prefer the author-written SEO fields from the CMS over the plain
// title / auto-excerpt when they're present.
const cf = (data.custom_fields ?? {}) as Record<string, unknown>;
const cfStr = (v: unknown): string | undefined =>
  typeof v === 'string' && v.trim() ? v.trim() : undefined;

const metaTitle = cfStr(cf.seo_title) || data.seo?.meta_title || data.title;
const description = cfStr(cf.seo_description) || data.seo?.meta_description || data.excerpt || undefined;
const authorName = data.author?.username || undefined;

// Route the crawler_signal hints into standard schema.org keywords + about.
const signal = parseCrawlerSignal(cf.crawler_signal);
const exploreAI = data.site_features?.explore_with_ai;

const schemas = [
  blogPostingSchema({
    title: data.title,
    description: description || '',
    url: postUrl,
    image: data.featured_image_url || undefined,
    authorName,
    datePublished: data.created_at || undefined,
    dateModified: data.updated_at || data.created_at || undefined,
    category: data.primary_category?.name || undefined,
    tags: data.tags?.map((t) => t.name) || undefined,
    keywords: signal.keywords,
    about: signal.about,
  }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog/' },
    { name: data.title, path: `/blog/${post.id}/` },
  ]),
];
---
<BaseLayout
  title={metaTitle}
  description={description}
  image={data.featured_image_url || undefined}
  canonicalOverride={data.seo?.canonical_url || undefined}
  ogType="article"
  publishedTime={data.created_at || undefined}
  modifiedTime={data.updated_at || data.created_at || undefined}
  author={authorName}
  keywords={data.tags?.map((t) => t.name).join(', ') || undefined}
  schema={schemas}
>
  <article class="article-shell">

    <header class="article-head">
      <a href="/blog/" class="back-link">&larr; All posts</a>

      {data.primary_category && (
        <div class="article-eyebrow">{data.primary_category.name}</div>
      )}

      <h1 class="article-title">{data.title}</h1>

      <div class="article-meta">
        {data.author?.username && <span class="byline">By {data.author.username}</span>}
        {dateLabel && (
          <>
            <span class="dot">·</span>
            <time datetime={data.created_at ?? ''}>{dateLabel}</time>
          </>
        )}
      </div>

      <ExploreWithAI
        enabled={exploreAI?.enabled ?? false}
        providers={exploreAI?.providers ?? {}}
        canonicalUrl={canonicalUrl}
        type={data.type ?? 'post'}
      />
    </header>

    {data.featured_image_url && (
      <div class="article-featured">
        <img src={data.featured_image_url} alt={data.title} />
      </div>
    )}

    <div class="article-body" set:html={data.content_html ?? ''} />

    {data.tags && data.tags.length > 0 && (
      <div class="article-tags">
        <span class="article-tags-label">Tags</span>
        {data.tags.map((t) => <span class="tag">#{t.slug}</span>)}
      </div>
    )}

    <div class="article-footer">
      <a href="/blog/" class="btn">&larr; Back to all posts</a>
    </div>

  </article>
</BaseLayout>

<style>
  .article-shell {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .article-head {
    padding: 3rem 0 2rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--hns-violet);
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  .back-link:hover { text-decoration: underline; }

  .article-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hns-violet);
    margin-bottom: 1rem;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 1.5rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  .article-meta .dot { opacity: 0.5; }
  .byline { color: var(--text-secondary); }

  /* Featured image breaks slightly out of the text column for visual impact */
  .article-featured {
    margin: 1rem -2rem 2.5rem;
    border-radius: 14px;
    overflow: hidden;
  }

  .article-featured img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-radius: 0;
    margin: 0;
  }

  /* ── Article body typography ── */
  .article-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-primary);
  }

  .article-body :global(p) {
    margin-bottom: 1.4rem;
  }

  .article-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.85rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 3rem 0 1rem;
    color: var(--text-primary);
  }

  .article-body :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.25;
    margin: 2.25rem 0 0.85rem;
    color: var(--text-primary);
  }

  .article-body :global(h4) {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    margin: 1.75rem 0 0.5rem;
    color: var(--text-primary);
  }

  .article-body :global(a) {
    color: var(--hns-violet);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .article-body :global(a:hover) {
    color: var(--hns-violet-deep);
  }

  .article-body :global(strong) { color: var(--text-primary); }
  .article-body :global(em) { font-style: italic; }

  .article-body :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 2rem 0;
    display: block;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--hns-violet);
    padding: 0.25rem 0 0.25rem 1.5rem;
    margin: 2rem 0;
    color: var(--text-primary);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.5;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-body :global(pre),
  .article-body :global(code) {
    font-family: var(--font-mono);
  }

  .article-body :global(code) {
    background: rgba(105, 58, 250, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.92em;
    color: var(--hns-violet);
  }

  .article-body :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .article-body :global(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin: 3rem 0;
  }

  /* ── Tags ── */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--glass-border);
  }

  .article-tags-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-right: 0.5rem;
  }

  .tag {
    background: rgba(105, 58, 250, 0.08);
    color: var(--hns-violet);
    border: 1px solid rgba(105, 58, 250, 0.2);
    padding: 0.3rem 0.7rem;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .article-footer {
    margin-top: 3rem;
    padding-bottom: 5rem;
  }

  @media (max-width: 760px) {
    .article-featured { margin: 1rem 0 2rem; }
    .article-body :global(h2) { font-size: 1.5rem; margin: 2.25rem 0 0.85rem; }
    .article-body :global(h3) { font-size: 1.25rem; }
  }
</style>
