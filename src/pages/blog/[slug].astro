---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'posts'> };
const { post } = Astro.props as Props;
const { data } = post;

const dateLabel = data.created_at
  ? new Date(data.created_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---
<BaseLayout
  title={data.seo?.meta_title || data.title}
  description={data.seo?.meta_description || data.excerpt || undefined}
  image={data.featured_image_url || undefined}
>
  <article class="post">
    <a href="/blog/" class="back-link">← All posts</a>
    <h1>{data.title}</h1>
    <div class="post-meta">
      {data.author?.username && <span>By {data.author.username}</span>}
      {dateLabel && (
        <>
          <span class="dot">•</span>
          <time datetime={data.created_at ?? ''}>{dateLabel}</time>
        </>
      )}
      {data.primary_category && (
        <>
          <span class="dot">•</span>
          <span>{data.primary_category.name}</span>
        </>
      )}
    </div>

    {data.featured_image_url && (
      <img src={data.featured_image_url} alt={data.title} class="featured" />
    )}

    <div class="post-body" set:html={data.content_html ?? ''} />

    {data.tags && data.tags.length > 0 && (
      <div class="tags">
        {data.tags.map((t) => <span class="tag">#{t.slug}</span>)}
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .post {
    background: var(--card-bg);
    border: 1px solid #334155;
    border-radius: 12px;
    padding: 2.5rem;
    margin-bottom: 3rem;
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .post h1 {
    margin-bottom: 1rem;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: #94a3b8;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .post-meta .dot { opacity: 0.5; }
  .featured {
    width: 100%;
    border-radius: 8px;
    margin-bottom: 2rem;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    margin-top: 2rem;
  }
  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }
  .post-body :global(a) {
    text-decoration: underline;
  }
  .post-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--primary-color);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #cbd5e1;
    font-style: italic;
  }
  .post-body :global(pre),
  .post-body :global(code) {
    font-family: var(--font-mono);
  }
  .post-body :global(pre) {
    background: #0f172a;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
  }
  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }
  .tags {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    background: #0f172a;
    color: var(--primary-color);
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
</style>
