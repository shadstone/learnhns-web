---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrackingScripts from "../components/TrackingScripts.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Your gateway to exploring the future of decentralized domains with Handshake (HNS).",
  image = "/og-image.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://learnhns.com');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | LearnHNS</title>
  <meta name="description" content={description} />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | LearnHNS`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, canonicalURL)} />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={`${title} | LearnHNS`} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, canonicalURL)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,700;1,9..144,400;1,9..144,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet" />

  <!-- Favicons and App Icons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <TrackingScripts />
</body>
</html>
