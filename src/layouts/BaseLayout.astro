---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrackingScripts from "../components/TrackingScripts.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Your gateway to exploring the future of decentralized domains with Handshake (HNS).",
  image = "/handshake-white.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://learnhns.com');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | LearnHNS</title>
  <meta name="description" content={description} />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | LearnHNS`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, canonicalURL)} />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={`${title} | LearnHNS`} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, canonicalURL)} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <TrackingScripts />
</body>
</html>
