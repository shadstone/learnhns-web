---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrackingScripts from "../components/TrackingScripts.astro";
import "../styles/global.css";

export interface Props {
  /** Page title (sans " | LearnHNS" suffix — added automatically) */
  title: string;
  /** Meta description (≤160 chars ideal) */
  description?: string;
  /** OG image URL — relative path is resolved against canonical */
  image?: string;
  /** Override the canonical URL (e.g. blog posts with an off-site original) */
  canonicalOverride?: string;
  /** og:type — defaults to "website", use "article" for blog posts */
  ogType?: 'website' | 'article' | 'profile';
  /** Comma-separated keywords for meta keywords (minor SEO signal) */
  keywords?: string;
  /** Set true to emit robots noindex (used for skill.md-like utility pages) */
  noindex?: boolean;
  /** ISO 8601 publish/update times for og:article + Article schema */
  publishedTime?: string;
  modifiedTime?: string;
  /** Author display name for og:article */
  author?: string;
  /** Page title is rendered as-is when true (no " | LearnHNS" suffix) */
  hideTitleSuffix?: boolean;
  /** Structured-data JSON-LD objects — emitted as one or many <script type="application/ld+json"> */
  schema?: object | object[];
};

const {
  title,
  description = "Your gateway to exploring the future of decentralized domains with Handshake (HNS).",
  image = "/og-image.jpg",
  canonicalOverride,
  ogType = 'website',
  keywords,
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
  hideTitleSuffix = false,
  schema,
} = Astro.props;

const siteUrl = Astro.site || new URL('https://learnhns.com');
const computedCanonical = new URL(Astro.url.pathname, siteUrl).toString();
const canonicalURL = canonicalOverride || computedCanonical;
const ogImage = new URL(image, siteUrl).toString();
const fullTitle = hideTitleSuffix ? title : `${title} | LearnHNS`;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  {author && <meta name="author" content={author} />}
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <meta name="theme-color" content="#ffffff" id="theme-color-meta" />
  <meta name="color-scheme" content="light dark" />

  <!-- No-FOUC theme script — sets [data-theme] on <html> before paint.
       Reads saved preference; falls back to system preference. -->
  <script is:inline>
    (function () {
      try {
        var stored = localStorage.getItem('learnhns-theme'); // 'light' | 'dark' | 'system' | null
        var pref = stored || 'system';
        var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var resolved = pref === 'system' ? (systemDark ? 'dark' : 'light') : pref;
        document.documentElement.setAttribute('data-theme', resolved);
        document.documentElement.setAttribute('data-theme-pref', pref);
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', resolved === 'dark' ? '#0b0d12' : '#ffffff');
      } catch (e) { /* localStorage blocked or other — leave default light */ }
    })();
  </script>

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="LearnHNS" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={`${title} — LearnHNS`} />
  {ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )}
  {ogType === 'article' && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )}
  {ogType === 'article' && author && (
    <meta property="article:author" content={author} />
  )}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@learnhns" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={`${title} — LearnHNS`} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,700;1,9..144,400;1,9..144,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet" />

  <!-- Favicons and App Icons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Structured data -->
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <slot name="head" />
</head>
<body>
  <div class="hello-bar">
    <p>
      Join the SkyInclude & OwnTheDot LearnHNS Competition!
      <a href="/submitentry/">Learn more & Submit</a>
    </p>
  </div>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <TrackingScripts />
</body>
</html>
