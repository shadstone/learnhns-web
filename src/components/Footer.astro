---
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-content">
    <nav class="footer-nav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/learn/">Learn HNS</a></li>
        <li><a href="/media/">Reading & Media</a></li>
        <li><a href="/podcasts/">Podcasts</a></li>
        <li><a href="/services/">Services</a></li>
        <li><a href="/dns/">How DNS Works</a></li>
        <li><a href="/privacy/">Privacy Policy</a></li>
      </ul>
    </nav>
    <p class="copyright">
      &copy; {currentYear} Learn HNS. Site maintained by SkyInclude, for updates or inclusions <a href="https://skyinclude.com/contact" target="_blank" rel="noopener noreferrer">contact us</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--footer-bg);
    color: #ffffff;
    padding: 3rem 0;
    margin-top: auto;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .footer-nav {
    margin-bottom: 2rem;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
  }

  .footer-nav a {
    color: #ffffff;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--secondary-color);
  }

  .copyright {
    font-size: 0.9rem;
    color: #a0aab2;
  }

  .copyright a {
    color: var(--secondary-color);
    text-decoration: none;
  }

  .copyright a:hover {
    text-decoration: underline;
  }
</style>
