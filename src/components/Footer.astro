---
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo-lockup" aria-label="LearnHNS home">
        <img src="/learnhnsicon-dark.svg" alt="" onerror="this.style.display='none'" />
        <span>LearnHNS</span>
      </a>
      <p>
        The independent resource hub for Handshake — the decentralized
        naming protocol that gives you ownership, not a lease.
      </p>
      <div class="social-links">
        <a href="https://x.com/learnhns" class="social-link" aria-label="X / Twitter" target="_blank" rel="noopener">𝕏</a>
        <a href="https://github.com/learnhns" class="social-link" aria-label="GitHub" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>Learn</h4>
        <a href="/learn/">Overview</a>
        <a href="/start/">Getting Started</a>
        <a href="/dns/">How DNS Works</a>
        <a href="/media/">Reading &amp; Media</a>
        <a href="/blog/">Blog</a>
      </div>
      <div class="footer-col">
        <h4>Ecosystem</h4>
        <a href="/market/">Marketplace</a>
        <a href="/services/">Wallets &amp; Services</a>
        <a href="/podcasts/">Podcasts</a>
        <a href="/privacy/">Privacy</a>
        <a href="/llms.txt" target="_blank">llms.txt</a>
        <a href="/skill.md" target="_blank">skill.md</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>&copy; {currentYear} LearnHNS &mdash; Not affiliated with Handshake Foundation</span>
    <span>
      Maintained by <a href="https://skyinclude.com/contact" target="_blank" rel="noopener">SkyInclude</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--glass-border);
    background: rgba(0, 0, 0, 0.02);
    padding: 3rem 2rem 1.5rem;
    margin-top: 4rem;
    color: var(--text-secondary);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
  }

  .logo-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .logo-lockup img { height: 26px; width: auto; border-radius: 0; }

  .logo-lockup span {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }

  .footer-brand p {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 360px;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .social-links { display: flex; gap: 0.6rem; }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px; height: 34px;
    border-radius: 8px;
    background: #ffffff;
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .social-link:hover {
    color: var(--hns-violet);
    border-color: var(--hns-violet);
    background: rgba(105, 58, 250, 0.04);
    text-decoration: none;
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.85rem;
  }

  .footer-col a {
    display: block;
    font-size: 0.82rem;
    color: var(--text-secondary);
    text-decoration: none;
    margin-bottom: 0.45rem;
    transition: color 0.15s ease;
  }

  .footer-col a:hover { color: var(--hns-violet); text-decoration: none; }

  .footer-bottom {
    max-width: 1200px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .footer-bottom a { color: var(--hns-violet); }

  @media (max-width: 800px) {
    .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
    .footer-links { gap: 2rem; }
    .footer-bottom { justify-content: center; text-align: center; }
  }
</style>
