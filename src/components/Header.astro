---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header" data-nav-open="false">
  <div class="header-inner">
    <a href="/" class="logo-lockup" aria-label="LearnHNS home">
      <img src="/learnhnsicon-dark.svg" alt="" onerror="this.style.display='none'" />
      <span>LearnHNS</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-controls="primary-nav"
      aria-expanded="false"
    >
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <nav class="main-nav" id="primary-nav" aria-label="Primary">
      <a href="/learn/" class:list={[{ 'is-active': isActive('/learn') }]}>Learn</a>
      <a href="/dns/" class:list={[{ 'is-active': isActive('/dns') }]}>DNS</a>
      <a href="/media/" class:list={[{ 'is-active': isActive('/media') }]}>Media</a>
      <a href="/podcasts/" class:list={[{ 'is-active': isActive('/podcasts') }]}>Podcasts</a>
      <a href="/services/" class:list={[{ 'is-active': isActive('/services') }]}>Services</a>
      <a href="/blog/" class:list={[{ 'is-active': isActive('/blog') }]}>Blog</a>
      <a href="/market/" class:list={[{ 'is-active': isActive('/market') }]}>Market</a>
      <a href="/start/" class="cta-pill">Start Learning &rarr;</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    padding: 0 2rem;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--glass-border);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .logo-lockup {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-lockup:hover {
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-lockup img {
    height: 28px;
    width: auto;
    border-radius: 0;
  }

  .logo-lockup span {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .main-nav a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
    letter-spacing: 0.01em;
  }

  .main-nav a:hover {
    color: var(--text-primary);
    background: rgba(0, 0, 0, 0.04);
    text-decoration: none;
  }

  .main-nav a.is-active {
    color: var(--hns-violet);
  }

  /* CTA pill overrides the generic .main-nav a styling */
  .main-nav .cta-pill {
    margin-left: 0.5rem;
    font-size: 0.825rem;
    padding: 0.5rem 1.1rem !important;
  }

  .main-nav .cta-pill:hover {
    background: var(--hns-violet-deep) !important;
    color: #ffffff !important;
  }

  /* ── Hamburger toggle — only visible on mobile ── */
  .nav-toggle {
    display: none;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .nav-toggle:hover {
    border-color: var(--hns-violet);
    background: rgba(105, 58, 250, 0.04);
  }

  .nav-toggle-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }

  .nav-toggle-bars span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  /* Animate to X when open */
  [data-nav-open="true"] .nav-toggle-bars span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  [data-nav-open="true"] .nav-toggle-bars span:nth-child(2) {
    opacity: 0;
  }
  [data-nav-open="true"] .nav-toggle-bars span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Compact desktop layout ── */
  @media (max-width: 900px) {
    .site-header { padding: 0 1rem; }
    .main-nav { gap: 0.1rem; }
    .main-nav a { padding: 0.3rem 0.5rem; font-size: 0.78rem; }
  }

  /* ── Mobile: hamburger replaces nav; drawer slides down ── */
  @media (max-width: 760px) {
    .nav-toggle { display: inline-flex; }

    .main-nav {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: #ffffff;
      border-bottom: 1px solid var(--glass-border);
      padding: 1rem 1.25rem 1.5rem;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);

      /* Hidden by default */
      transform: translateY(-8px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: transform 0.25s ease, opacity 0.2s ease, visibility 0s linear 0.25s;
    }

    [data-nav-open="true"] .main-nav {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: transform 0.25s ease, opacity 0.2s ease, visibility 0s;
    }

    .main-nav a {
      padding: 0.85rem 0.75rem;
      font-size: 0.95rem;
      border-radius: 8px;
      border-bottom: 1px solid var(--glass-border);
    }

    .main-nav a:last-of-type {
      border-bottom: none;
    }

    .main-nav .cta-pill {
      margin: 0.75rem 0 0 !important;
      padding: 0.85rem 1.25rem !important;
      font-size: 0.95rem;
      text-align: center;
      border-bottom: none !important;
    }
  }
</style>

<script>
  // Mobile nav drawer toggle.
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = header?.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = header?.querySelector<HTMLElement>('.main-nav');

  if (header && toggle && nav) {
    const setOpen = (open: boolean) => {
      header.setAttribute('data-nav-open', String(open));
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    toggle.addEventListener('click', () => {
      const isOpen = header.getAttribute('data-nav-open') === 'true';
      setOpen(!isOpen);
    });

    // Close when a nav link is clicked (drawer should dismiss on navigation)
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.getAttribute('data-nav-open') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    // Close if viewport grows past the mobile breakpoint
    const mq = window.matchMedia('(min-width: 761px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>
