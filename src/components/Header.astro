---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header" data-nav-open="false">
  <div class="header-inner">
    <a href="/" class="logo-lockup" aria-label="LearnHNS home">
      <img class="logo-light" src="/learnhnsicon-dark.svg" alt="" onerror="this.style.display='none'" />
      <img class="logo-dark" src="/learnhnsicon.svg" alt="" onerror="this.style.display='none'" />
      <span>LearnHNS</span>
    </a>

    <nav class="main-nav" id="primary-nav" aria-label="Primary">
      <a href="/learn/" class:list={[{ 'is-active': isActive('/learn') }]}>Learn</a>
      <a href="/dns/" class:list={[{ 'is-active': isActive('/dns') }]}>DNS</a>
      <a href="/media/" class:list={[{ 'is-active': isActive('/media') }]}>Media</a>
      <a href="/podcasts/" class:list={[{ 'is-active': isActive('/podcasts') }]}>Podcasts</a>
      <a href="/services/" class:list={[{ 'is-active': isActive('/services') }]}>Services</a>
      <a href="/blog/" class:list={[{ 'is-active': isActive('/blog') }]}>Blog</a>
      <a href="/market/" class:list={[{ 'is-active': isActive('/market') }]}>Market</a>
      <a href="/start/" class="cta-pill">Start Learning &rarr;</a>
    </nav>

    <div class="header-actions">
      <button
        class="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg class="theme-icon theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
        </svg>
        <svg class="theme-icon theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="theme-icon theme-icon-system" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="13" rx="2" />
          <path d="M8 21h8M12 17v4" />
        </svg>
      </button>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-controls="primary-nav"
        aria-expanded="false"
      >
        <span class="nav-toggle-bars" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    padding: 0 2rem;
    background: var(--header-bg);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--glass-border);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* Push the nav (and the actions that follow) to the right end */
  .main-nav { margin-left: auto; }

  .logo-lockup {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-lockup:hover {
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-lockup img {
    height: 28px;
    width: auto;
    border-radius: 0;
  }

  .logo-lockup span {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .main-nav a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
    letter-spacing: 0.01em;
  }

  .main-nav a:hover {
    color: var(--text-primary);
    background: var(--hover-bg);
    text-decoration: none;
  }

  .main-nav a.is-active {
    color: var(--hns-violet);
  }

  /* CTA pill overrides the generic .main-nav a styling */
  .main-nav .cta-pill {
    margin-left: 0.5rem;
    font-size: 0.825rem;
    padding: 0.5rem 1.1rem !important;
  }

  .main-nav .cta-pill:hover {
    background: var(--hns-violet-deep) !important;
    color: #ffffff !important;
  }

  /* Logo swap rules live further down with the :global() escape */

  /* ── Header right-side actions cluster ── */
  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto; /* pushes actions right on mobile when nav is absolute */
  }

  /* ── Theme toggle button ── */
  .theme-toggle {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    cursor: pointer;
    padding: 0;
    color: var(--text-secondary);
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: var(--hns-violet);
    background: rgba(105, 58, 250, 0.06);
    color: var(--hns-violet);
  }

  .theme-icon { display: none; }
  /* Use :global() on the ancestor so Astro doesn't scope <html> to a
     data-astro-cid attribute it'll never have. */
  :global([data-theme-pref="light"]) .theme-icon-sun { display: block; }
  :global([data-theme-pref="dark"]) .theme-icon-moon { display: block; }
  :global([data-theme-pref="system"]) .theme-icon-system { display: block; }
  /* Same issue for the logo swap */
  .logo-light { display: inline-block; }
  .logo-dark { display: none; }
  :global([data-theme="dark"]) .logo-light { display: none; }
  :global([data-theme="dark"]) .logo-dark { display: inline-block; }

  /* ── Hamburger toggle — only visible on mobile ── */
  .nav-toggle {
    display: none;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .nav-toggle:hover {
    border-color: var(--hns-violet);
    background: rgba(105, 58, 250, 0.04);
  }

  .nav-toggle-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }

  .nav-toggle-bars span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  /* Animate to X when open */
  [data-nav-open="true"] .nav-toggle-bars span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  [data-nav-open="true"] .nav-toggle-bars span:nth-child(2) {
    opacity: 0;
  }
  [data-nav-open="true"] .nav-toggle-bars span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Compact desktop layout ── */
  @media (max-width: 900px) {
    .site-header { padding: 0 1rem; }
    .main-nav { gap: 0.1rem; }
    .main-nav a { padding: 0.3rem 0.5rem; font-size: 0.78rem; }
  }

  /* ── Mobile: hamburger replaces nav; drawer slides down ── */
  @media (max-width: 760px) {
    .nav-toggle { display: inline-flex; }

    .main-nav {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: var(--drawer-bg);
      border-bottom: 1px solid var(--glass-border);
      padding: 1rem 1.25rem 1.5rem;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);

      /* Hidden by default */
      transform: translateY(-8px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: transform 0.25s ease, opacity 0.2s ease, visibility 0s linear 0.25s;
    }

    [data-nav-open="true"] .main-nav {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: transform 0.25s ease, opacity 0.2s ease, visibility 0s;
    }

    .main-nav a {
      padding: 0.85rem 0.75rem;
      font-size: 0.95rem;
      border-radius: 8px;
      border-bottom: 1px solid var(--glass-border);
    }

    .main-nav a:last-of-type {
      border-bottom: none;
    }

    .main-nav .cta-pill {
      margin: 0.75rem 0 0 !important;
      padding: 0.85rem 1.25rem !important;
      font-size: 0.95rem;
      text-align: center;
      border-bottom: none !important;
    }
  }
</style>

<script>
  // Mobile nav drawer toggle.
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = header?.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = header?.querySelector<HTMLElement>('.main-nav');

  if (header && toggle && nav) {
    const setOpen = (open: boolean) => {
      header.setAttribute('data-nav-open', String(open));
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    toggle.addEventListener('click', () => {
      const isOpen = header.getAttribute('data-nav-open') === 'true';
      setOpen(!isOpen);
    });

    // Close when a nav link is clicked (drawer should dismiss on navigation)
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.getAttribute('data-nav-open') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    // Close if viewport grows past the mobile breakpoint
    const mq = window.matchMedia('(min-width: 761px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  }

  // Theme toggle — cycles light → dark → system → light…
  const themeToggle = header?.querySelector<HTMLButtonElement>('.theme-toggle');
  const themeOrder: Array<'light' | 'dark' | 'system'> = ['light', 'dark', 'system'];

  const applyTheme = (pref: 'light' | 'dark' | 'system') => {
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const resolved = pref === 'system' ? (systemDark ? 'dark' : 'light') : pref;
    document.documentElement.setAttribute('data-theme', resolved);
    document.documentElement.setAttribute('data-theme-pref', pref);
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute('content', resolved === 'dark' ? '#0b0d12' : '#ffffff');
    try { localStorage.setItem('learnhns-theme', pref); } catch (e) { /* ignore */ }
  };

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const current = (document.documentElement.getAttribute('data-theme-pref') || 'system') as 'light' | 'dark' | 'system';
      const next = themeOrder[(themeOrder.indexOf(current) + 1) % themeOrder.length];
      applyTheme(next);
    });
  }

  // Re-resolve when system pref changes (if user is on 'system')
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (document.documentElement.getAttribute('data-theme-pref') === 'system') {
      applyTheme('system');
    }
  });
</script>
