---
interface Props {
  editUrl?: string;
  archived?: boolean;
  mirroredFrom?: string;
}

const { editUrl, archived = false, mirroredFrom } = Astro.props;
---
<div class:list={['docs-archive-notice', { 'docs-archive-notice--historical': archived }]}>
  <p>
    {archived ? (
      <>
        <strong>Historical page:</strong> Namebase shut down in June 2026. This page is preserved for reference only — do not follow links to namebase.io services (they are offline). For current tooling, start at <a href="/start/">/start/</a>.
      </>
    ) : (
      <>
        <strong>Archive Notice:</strong> This documentation was originally published by Namebase (closed June 2026) and is preserved by the LearnHNS community. Pages may reference services that no longer exist — see current guides at <a href="/start/">/start/</a> or <a href="https://skyinclude.com/blog/namebase-wind-down/" target="_blank" rel="noopener">SkyInclude's wind-down explainer</a>.
      </>
    )}
  </p>
  {mirroredFrom && (
    <p class="docs-mirror-note">
      Mirrored from the former Namebase blog: <a href={mirroredFrom} rel="nofollow noopener">{mirroredFrom}</a>
    </p>
  )}
  {editUrl && (
    <a href={editUrl} target="_blank" rel="noopener" class="docs-edit-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      Edit this page on GitHub
    </a>
  )}
</div>

<style>
  .docs-archive-notice {
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: rgba(105, 58, 250, 0.05);
    border: 1px solid var(--hns-violet);
    border-radius: 8px;
  }

  .docs-archive-notice--historical {
    background: rgba(180, 120, 0, 0.08);
    border-color: rgba(180, 120, 0, 0.45);
  }

  .docs-mirror-note {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .docs-archive-notice p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .docs-archive-notice a {
    color: var(--hns-violet);
    font-weight: 600;
  }

  .docs-edit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-weight: 600;
    text-decoration: none;
  }

  .docs-edit-link:hover {
    text-decoration: underline;
  }
</style>